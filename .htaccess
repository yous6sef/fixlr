<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Enforce HTTPS for SEO (SSL boosts rankings)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
    
    # Remove .php extension from URLs (clean URLs boost SEO)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^([^\.]+)$ $1.php [NC, L]
    
    # Handle direct .php requests
    RewriteCond %{REQUEST_URI} \.php$
    RewriteRule ^(.*)$ $1 [L]
    
    # Remove trailing slashes (consistency for SEO)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.+)/$ /$1 [L,R=301]
</IfModule>

# ============================================================================
# GZIP COMPRESSION (Critical for SEO - Page Speed Metrics)
# ============================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
    AddOutputFilter DEFLATE html js css
    AddEncoding gzip .gz
    <FilesMatch "\.(js|css|html|xml|txt)$">
        Header append Vary: Accept-Encoding
    </FilesMatch>
</IfModule>

# ============================================================================
# BROWSER CACHING (Core Web Vitals - Critical for Ranking)
# ============================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/html "access plus 1 day"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 90 days"
    ExpiresByType image/gif "access plus 90 days"
    ExpiresByType image/png "access plus 90 days"
    ExpiresByType image/webp "access plus 90 days"
    ExpiresByType image/svg+xml "access plus 90 days"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/manifest+json "access plus 30 days"
    ExpiresByType image/x-icon "access plus 30 days"
    ExpiresDefault "access plus 2 days"
</IfModule>

# ============================================================================
# SECURITY HEADERS (Prevent De-indexing & Improve Trust)
# ============================================================================
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://connect.facebook.net https://platform.twitter.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:;"
    Header unset ETag
    Header always unset Server
    Header always unset X-Powered-By
</IfModule>

# Ensure proper MIME types
<IfModule mod_mime.c>
    AddType text/html .html
    AddType text/css .css
    AddType application/javascript .js
    AddType application/json .json
    AddType image/svg+xml .svg .svgz
    AddType application/font-woff .woff
    AddType application/font-woff2 .woff2
    AddEncoding gzip .svgz
</IfModule>

# Disable directory listing (Prevent exposing structure)
Options -Indexes

# Block access to sensitive files
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>
