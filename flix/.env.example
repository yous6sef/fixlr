# ========== FLIX MARKETPLACE - ENVIRONMENT CONFIGURATION ==========
# Copy this file to .env and update with actual values

# ========== APPLICATION ==========
NODE_ENV=development
APP_NAME=Flix Marketplace
APP_VERSION=1.0.0
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001
PORT=3001
SOCKET_PORT=3000
HOST=localhost

# ========== DATABASE ==========
# PostgreSQL Connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=flix
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flix
DB_SSL=false
# Database Pool Settings
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE=30000
DB_CONN_TIMEOUT=2000

# ========== REDIS CACHE ==========
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
REDIS_DB=0
REDIS_TTL=3600

# ========== AUTHENTICATION ==========
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ========== SECURITY ==========
BCRYPT_ROUNDS=10
CORS_ORIGINS=http://localhost:3001,http://localhost:8000,http://localhost:3000
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
MAX_LOGIN_ATTEMPTS=5
LOGIN_WINDOW=900000

# ========== HERE MAPS API ==========
HERE_API_KEY=your-here-api-key
HERE_BASE_URL=https://geocode.search.hereapi.com/v1

# ========== STRIPE PAYMENT ==========
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_PUBLIC_KEY=pk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ========== GOOGLE AI ==========
GOOGLE_AI_KEY=your-google-ai-api-key

# ========== EMAIL SERVICE ==========
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-service-api-key
EMAIL_FROM=noreply@flixmarketplace.com
EMAIL_FROM_NAME=Flix Marketplace

# ========== FIREBASE ==========
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket

# ========== LOGGING ==========
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DESTINATION=file
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ========== ERROR TRACKING (SENTRY) ==========
SENTRY_ENABLED=false
SENTRY_DSN=https://your-sentry-dsn
SENTRY_TRACE_RATE=0.1

# ========== STORAGE ==========
STORAGE_TYPE=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_MIMES=image/jpeg,image/png,application/pdf

# ========== CLOUDINARY STORAGE ==========
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset

# ========== BUSINESS LOGIC ==========
COMMISSION_PERCENT=0.20
TAX_PERCENT=0.15
APPROVAL_RADIUS=5
MIN_WORKER_RATING=3.5
UNPAID_THRESHOLD=7

# ========== FEATURE FLAGS ==========
FEATURE_STRIPE=false
FEATURE_EMAIL=false
FEATURE_AUDIO=false
FEATURE_SEARCH=true
FEATURE_AI=true
