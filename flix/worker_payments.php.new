                    <div class="breakdown-label"><?php echo t('platform_commission'); ?> (20%)</div>
                    <div class="breakdown-value">- <?php echo $earnings_breakdown['platform_commission']; ?> EGP</div>
                </div>
                <div class="breakdown-item success">
                    <div class="breakdown-label"><?php echo t('your_net_earnings'); ?></div>
                    <div class="breakdown-value"><?php echo $earnings_breakdown['net_earnings']; ?> EGP</div>
                </div>
            </div>
            
            <button class="action-btn"><?php echo t('request_payment'); ?></button>
        </div>
        
        <div class="card">
            <h2><?php echo t('recent_earnings'); ?></h2>
            <table class="table">
                <thead>
                    <tr>
                        <th><?php echo t('services'); ?></th>
                        <th><?php echo t('customer'); ?></th>
                        <th><?php echo t('checking_fee'); ?></th>
                        <th><?php echo t('fixing_fee'); ?></th>
                        <th><?php echo t('total'); ?></th>
                        <th><?php echo t('commission'); ?></th>
                        <th><?php echo t('your_share'); ?></th>
                        <th><?php echo t('date'); ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($recent_earnings as $earning): ?>
                    <tr>
                        <td><span class="service-badge"><?php echo $earning['service']; ?></span></td>
                        <td><?php echo $earning['customer']; ?></td>
                        <td><?php echo $earning['checking']; ?> EGP</td>
                        <td><?php echo $earning['fixing']; ?> EGP</td>
                        <td><?php echo $earning['total']; ?> EGP</td>
                        <td><span class="negative">- <?php echo $earning['commission']; ?> EGP</span></td>
                        <td><span class="positive">+ <?php echo $earning['your_share']; ?> EGP</span></td>
                        <td><?php echo $earning['date']; ?></td>
                    </tr>
                    <?php endforeach; ?>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
