    ['id' => 3, 'service' => 'Plumbing', 'customer' => 'سارة محمود', 'checking' => 300, 'fixing' => 200, 'total' => 500, 'commission' => 100, 'your_share' => 400, 'date' => '2026-05-24'],
];
