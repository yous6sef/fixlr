<!DOCTYPE html>
<html lang="<?php echo $lang; ?>" dir="<?php echo $dir; ?>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?php echo t('earnings'); ?> - FLIX</title>
    <link rel="stylesheet" href="css/premium-ui.css">
    <style>
        body { background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); min-height: 100vh; padding: 20px; }
        .container { max-width: 1200px; margin: 0 auto; }
        h1 { text-align: center; margin-bottom: 30px; color: #111827; }
        .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px; }
        .stat-card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .stat-card.primary { background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%); color: white; }
        .stat-card.success { background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%); color: white; }
        .stat-card.warning { background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white; }
        .stat-label { font-size: 0.9rem; opacity: 0.9; margin-bottom: 10px; }
        .stat-value { font-size: 2.5rem; font-weight: 700; margin-bottom: 5px; }
        .stat-desc { font-size: 0.85rem; opacity: 0.85; }
        .card { background: white; padding: 25px; border-radius: 12px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        h2 { color: #111827; border-bottom: 2px solid #0ea5e9; padding-bottom: 15px; margin: 0 0 20px 0; }
        .breakdown-items { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 20px; }
        .breakdown-item { background: rgba(14, 165, 233, 0.05); padding: 15px; border-radius: 8px; border-left: 4px solid #0ea5e9; }
        .breakdown-item.commission { border-left-color: #ef4444; background: rgba(239, 68, 68, 0.05); }
        .breakdown-item.success { border-left-color: #22c55e; background: rgba(34, 197, 94, 0.05); }
        .breakdown-label { font-size: 0.9rem; color: #6b7280; margin-bottom: 5px; }
        .breakdown-value { font-size: 1.5rem; font-weight: 700; color: #111827; }
        .breakdown-item.commission .breakdown-value { color: #ef4444; }
        .breakdown-item.success .breakdown-value { color: #22c55e; }
        .table { width: 100%; border-collapse: collapse; }
        .table th { background: #f3f4f6; padding: 12px; text-align: left; font-weight: 600; color: #6b7280; font-size: 0.9rem; }
        .table td { padding: 15px 12px; border-bottom: 1px solid #e5e7eb; }
        .table tr:hover { background: #f9fafb; }
        .service-badge { display: inline-block; padding: 4px 8px; background: #dbeafe; color: #1e40af; border-radius: 4px; font-size: 0.85rem; font-weight: 600; }
        .positive { color: #22c55e; font-weight: 600; }
        .negative { color: #ef4444; font-weight: 600; }
        .action-btn { padding: 10px 20px; background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%); color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: 600; }
        .action-btn:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(14, 165, 233, 0.3); }
    </style>
</head>
<body>
    <div class="container">
        <h1>💰 <?php echo t('earnings_dashboard'); ?></h1>
        
        <div class="stats-grid">
            <div class="stat-card primary">
